<?xml version="1.0" ?>
<!--
  balancebot_v3.urdf
  ==========================================

  PHYSICAL PARAMETERS (all measured/confirmed):
    Wheel radius:   0.03405m  (68.1mm diameter / 2, caliper measured)
    Wheel width:    0.027m    (27.0mm, caliper measured)
    Wheelbase:      0.203m    (centre-to-centre, derived below)
    Body width (Y): 0.157m    (15.7cm, measured)
    Body height(Z): 0.100m    (10.0cm, measured)
    Body depth (X): 0.060m    (estimated, adjust if needed)
    Body mass:      0.500kg   (estimate, weigh after assembly)

  WHEELBASE DERIVATION:
    Total measured span (L wheel centre → R wheel centre) = 20.3cm
    Box width = 15.7cm → half = 7.85cm
    Gap each side = (20.3 - 15.7) / 2 = 2.3cm
    Wheel centre Y offset = 7.85 + 2.3 = 10.15cm = 0.1015m
    Full wheelbase = 2 × 0.1015 = 0.203m

  MOTOR: Cytron SPG30-20K
    12V, 225RPM, 128mNm torque, 20:1 gear ratio
    No encoder — velocity observations removed

  IMU: MPU6050
    Mounted at TOP of body, perfectly centred
    Provides: pitch, pitch_rate, yaw, yaw_rate
    In PyBullet: readings come from getBasePositionAndOrientation()
                 and getBaseVelocity() on base_link
    The imu_link here represents physical mass/position of MPU6050
    so centre of mass calculation is accurate

  COORDINATE SYSTEM:
    X = forward/backward
    Y = left/right
    Z = up (gravity = -Z)

  SPAWN HEIGHT = wheel radius = 0.03405m
  so wheels sit exactly on ground plane at Z=0

  JOINT INDICES (used in balance_env_v2.py):
    joint 1 = left wheel
    joint 2 = right wheel
    joint 3 = imu (fixed — no movement)
-->

<robot name="balancebot_v3">

  <!-- ═══════════════════════════════════════════════════════════
       BASE LINK (robot body frame)
       Origin at wheel axle level, centred left-right and front-back
       Visual origin offset upward by half body height (0.05m)
  ═══════════════════════════════════════════════════════════ -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry>
        <!-- depth(X)=0.06  width(Y)=0.157  height(Z)=0.10 -->
        <box size="0.06 0.157 0.10"/>
      </geometry>
      <material name="blue">
        <color rgba="0.2 0.4 0.8 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry>
        <box size="0.06 0.157 0.10"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <mass value="0.500"/>
      <!--
        Inertia for box: depth(X)=0.06, width(Y)=0.157, height(Z)=0.10, mass=0.5kg
        ixx = m/12 * (Y² + Z²) = 0.5/12 * (0.157² + 0.10²) = 0.00144
        iyy = m/12 * (X² + Z²) = 0.5/12 * (0.06²  + 0.10²) = 0.00057
        izz = m/12 * (X² + Y²) = 0.5/12 * (0.06²  + 0.157²)= 0.00118
      -->
      <inertia ixx="0.00144" ixy="0.0" ixz="0.0"
               iyy="0.00057" iyz="0.0"
               izz="0.00118"/>
    </inertial>
  </link>

  <!-- ═══════════════════════════════════════════════════════════
       IMU LINK (MPU6050)
       Mounted at TOP of body frame, perfectly centred
       Fixed joint — does not move relative to body
       Mass included so CoM calculation is accurate
  ═══════════════════════════════════════════════════════════ -->
  <link name="imu_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <!-- MPU6050 physical size: 20mm × 16mm × 1.5mm -->
        <box size="0.02 0.016 0.0015"/>
      </geometry>
      <material name="green">
        <color rgba="0.0 0.8 0.2 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.02 0.016 0.0015"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <!-- MPU6050 weighs approximately 1g = 0.001kg -->
      <mass value="0.001"/>
      <inertia ixx="0.0000001" ixy="0.0" ixz="0.0"
               iyy="0.0000001" iyz="0.0"
               izz="0.0000001"/>
    </inertial>
  </link>

  <!-- Fixed joint — IMU rigidly attached at top of body, centred -->
  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <!--
      Top of body = 0.10m above axle, centred in X and Y
    -->
    <origin xyz="0 0 0.10" rpy="0 0 0"/>
  </joint>

  <!-- ═══════════════════════════════════════════════════════════
       LEFT WHEEL
       y offset = -wheelbase/2 = -0.1015m from centre
  ═══════════════════════════════════════════════════════════ -->
  <link name="left_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="1.5707963 0 0"/>
      <geometry>
        <cylinder radius="0.03405" length="0.027"/>
      </geometry>
      <material name="black">
        <color rgba="0.1 0.1 0.1 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5707963 0 0"/>
      <geometry>
        <cylinder radius="0.03405" length="0.027"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="1.5707963 0 0"/>
      <mass value="0.050"/>
      <!--
        Inertia for cylinder: radius=0.03405, length=0.027, mass=0.05kg
        ixx=iyy = m/12 * (3r² + l²) = 0.05/12 * (3×0.03405² + 0.027²) = 0.0000175
        izz     = m/2  * r²         = 0.05/2  * 0.03405²               = 0.0000290
      -->
      <inertia ixx="0.0000175" ixy="0.0" ixz="0.0"
               iyy="0.0000175" iyz="0.0"
               izz="0.0000290"/>
    </inertial>
  </link>

  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <!--
      y = -wheelbase/2 = -(0.203/2) = -0.1015m
      Wheelbase derivation: box_half(7.85cm) + gap(2.3cm) = 10.15cm
    -->
    <origin xyz="0 -0.1015 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.01" friction="0.01"/>
  </joint>

  <!-- ═══════════════════════════════════════════════════════════
       RIGHT WHEEL
       y offset = +wheelbase/2 = +0.1015m from centre
  ═══════════════════════════════════════════════════════════ -->
  <link name="right_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="1.5707963 0 0"/>
      <geometry>
        <cylinder radius="0.03405" length="0.027"/>
      </geometry>
      <material name="black">
        <color rgba="0.1 0.1 0.1 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5707963 0 0"/>
      <geometry>
        <cylinder radius="0.034" length="0.027"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="1.5707963 0 0"/>
      <mass value="0.050"/>
      <inertia ixx="0.0000175" ixy="0.0" ixz="0.0"
               iyy="0.0000175" iyz="0.0"
               izz="0.0000290"/>
    </inertial>
  </link>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <!--
      y = +wheelbase/2 = +(0.203/2) = +0.1015m
    -->
    <origin xyz="0 0.1015 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.01" friction="0.01"/>
  </joint>

</robot>
