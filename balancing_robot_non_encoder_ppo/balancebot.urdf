<?xml version="1.0" ?>
<!--
  balancebot_v2.urdf — v2_non_encoder_robot
  ==========================================

  PHYSICAL PARAMETERS (all measured/confirmed):
    Wheel radius:   0.034m  (68.1mm diameter, caliper measured)
    Wheel width:    0.027m  (27.0mm, caliper measured)
    Wheel base:     0.233m  (centre-to-centre, physically measured)
    Body width:     0.180m  (frame spec)
    Body height:    0.180m  (18cm, confirmed)
    Body depth:     0.060m  (estimated, adjust if needed)
    Body mass:      0.500kg (estimate, weigh after assembly)

  MOTOR: Cytron SPG30-20K
    12V, 225RPM, 128mNm torque, 20:1 gear ratio
    No encoder — velocity observations removed

  IMU: MPU6050
    Mounted at TOP of body, perfectly centred
    Provides: pitch, pitch_rate, yaw, yaw_rate
    In PyBullet: readings come from getBasePositionAndOrientation()
                 and getBaseVelocity() on base_link
    The imu_link here represents physical mass/position of MPU6050
    so centre of mass calculation is accurate

  COORDINATE SYSTEM:
    X = forward/backward
    Y = left/right
    Z = up (gravity = -Z)

  SPAWN HEIGHT = wheel radius = 0.034m
  so wheels sit exactly on ground plane at Z=0

  JOINT INDICES (used in balance_env_v2.py):
    joint 1 = left wheel
    joint 2 = right wheel
    joint 3 = imu (fixed — no movement)

  COMPONENT PLACEMENT (bottom to top from wheel axle):
    0.00m  wheel axle
    0.02m  L298N motor driver
    0.05m  Battery (GNB 1350mAh)
    0.08m  ESP32-S3
    0.11m  RPi Zero 2W
    0.18m  MPU6050 (top, centred) ← imu_link origin
-->

<robot name="balancebot_v2">

  <!-- ═══════════════════════════════════════════════════════════
       BASE LINK (robot body frame)
       Origin at wheel axle level, centred left-right and front-back
       Visual origin offset upward by half body height (0.09m)
  ═══════════════════════════════════════════════════════════ -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.09" rpy="0 0 0"/>
      <geometry>
        <box size="0.06 0.18 0.18"/>
      </geometry>
      <material name="blue">
        <color rgba="0.2 0.4 0.8 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.09" rpy="0 0 0"/>
      <geometry>
        <box size="0.06 0.18 0.18"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.09" rpy="0 0 0"/>
      <mass value="0.500"/>
      <!--
        Inertia for box: width=0.06, depth=0.18, height=0.18, mass=0.5kg
        ixx = m/12 * (depth² + height²) = 0.5/12 * (0.18² + 0.18²) = 0.00270
        iyy = m/12 * (width² + height²) = 0.5/12 * (0.06² + 0.18²) = 0.00165
        izz = m/12 * (width² + depth²)  = 0.5/12 * (0.06² + 0.18²) = 0.00165
      -->
      <inertia ixx="0.00270" ixy="0.0" ixz="0.0"
               iyy="0.00165" iyz="0.0"
               izz="0.00165"/>
    </inertial>
  </link>

  <!-- ═══════════════════════════════════════════════════════════
       IMU LINK (MPU6050)
       Mounted at TOP of body frame, perfectly centred
       Fixed joint — does not move relative to body
       Mass included so CoM calculation is accurate
       In PyBullet: pitch/yaw readings come from base_link
                   since imu_link is rigidly attached
  ═══════════════════════════════════════════════════════════ -->
  <link name="imu_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <!-- MPU6050 physical size: 20mm × 16mm × 1.5mm -->
        <box size="0.02 0.016 0.0015"/>
      </geometry>
      <material name="green">
        <color rgba="0.0 0.8 0.2 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.02 0.016 0.0015"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <!-- MPU6050 weighs approximately 1g = 0.001kg -->
      <mass value="0.001"/>
      <inertia ixx="0.0000001" ixy="0.0" ixz="0.0"
               iyy="0.0000001" iyz="0.0"
               izz="0.0000001"/>
    </inertial>
  </link>

  <!-- Fixed joint — IMU rigidly attached at top of body, centred -->
  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <!--
      Position: top of body = 0.18m above axle, centred in X and Y
      xyz = (0, 0, 0.18) — top of body height
    -->
    <origin xyz="0 0 0.18" rpy="0 0 0"/>
  </joint>

  <!-- ═══════════════════════════════════════════════════════════
       LEFT WHEEL
       y offset = -wheel_base/2 = -0.1165m from centre
  ═══════════════════════════════════════════════════════════ -->
  <link name="left_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="1.5707963 0 0"/>
      <geometry>
        <cylinder radius="0.034" length="0.027"/>
      </geometry>
      <material name="black">
        <color rgba="0.1 0.1 0.1 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5707963 0 0"/>
      <geometry>
        <cylinder radius="0.034" length="0.027"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="1.5707963 0 0"/>
      <mass value="0.050"/>
      <!--
        Inertia for cylinder: radius=0.034, length=0.027, mass=0.05kg
        ixx = iyy = m/12 * (3r² + l²) = 0.05/12 * (3×0.034² + 0.027²) = 0.0000148
        izz = m/2 * r²                 = 0.05/2  * 0.034²               = 0.0000289
      -->
      <inertia ixx="0.0000148" ixy="0.0" ixz="0.0"
               iyy="0.0000148" iyz="0.0"
               izz="0.0000289"/>
    </inertial>
  </link>

  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <!-- y = -wheel_base/2 = -0.233/2 = -0.1165m -->
    <origin xyz="0 -0.1165 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.01" friction="0.01"/>
  </joint>

  <!-- ═══════════════════════════════════════════════════════════
       RIGHT WHEEL
       y offset = +wheel_base/2 = +0.1165m from centre
  ═══════════════════════════════════════════════════════════ -->
  <link name="right_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="1.5707963 0 0"/>
      <geometry>
        <cylinder radius="0.034" length="0.027"/>
      </geometry>
      <material name="black">
        <color rgba="0.1 0.1 0.1 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5707963 0 0"/>
      <geometry>
        <cylinder radius="0.034" length="0.027"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="1.5707963 0 0"/>
      <mass value="0.050"/>
      <inertia ixx="0.0000148" ixy="0.0" ixz="0.0"
               iyy="0.0000148" iyz="0.0"
               izz="0.0000289"/>
    </inertial>
  </link>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <!-- y = +wheel_base/2 = +0.233/2 = +0.1165m -->
    <origin xyz="0 0.1165 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.01" friction="0.01"/>
  </joint>

</robot>
