<?xml version="1.0"?>
<robot name="myrobot">

  <material name="blue">
    <color rgba="0.0 0.5 1.0 1.0"/>
  </material>
  <material name="red">
    <color rgba="1.0 0.1 0.1 1.0"/>
  </material>
  <material name="yellow">
    <color rgba="1.0 0.8 0.0 1.0"/>
  </material>

  <!-- ═══════════════════════════
       CHASSIS
  ═══════════════════════════ -->
  <link name="base_link">
    <inertial>
      <mass value="0.7"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0"
               iyy="0.001" iyz="0.0"
               izz="0.002"/>
    </inertial>
    <visual>
      <geometry>
        <box size="0.20 0.15 0.08"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <!-- Collision box is slightly smaller in Z
         so wheels don't intersect chassis physics -->
    <collision>
      <geometry>
        <box size="0.20 0.15 0.06"/>
      </geometry>
    </collision>
  </link>

  <!-- ═══════════════════════════
       CAMERA
       Fixed to chassis top
       X=+0.05 forward
       Z=+0.06 = chassis half(0.04) + cam half(0.02)
  ═══════════════════════════ -->
  <link name="camera_link">
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.00001" ixy="0.0" ixz="0.0"
               iyy="0.00001" iyz="0.0"
               izz="0.00001"/>
    </inertial>
    <visual>
      <geometry>
        <box size="0.04 0.04 0.04"/>
      </geometry>
      <material name="yellow"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.04 0.04 0.04"/>
      </geometry>
    </collision>
  </link>

  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="0.05 0.0 0.06" rpy="0 0 0"/>
  </joint>

  <!-- ═══════════════════════════
       FRONT LEFT WHEEL
       X=+0.07, Y=+0.085, Z=-0.04
       rpy: roll 90° so cylinder
       stands upright like a wheel
  ═══════════════════════════ -->
  <link name="front_left_wheel">
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0"
               iyy="0.0001" iyz="0.0"
               izz="0.0001"/>
    </inertial>
    <visual>
      <geometry>
        <cylinder radius="0.025" length="0.02"/>
      </geometry>
      <material name="red"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.025" length="0.02"/>
      </geometry>
    </collision>
  </link>

  <joint name="front_left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="front_left_wheel"/>
    <origin xyz="0.07 0.085 -0.04" rpy="1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- FRONT RIGHT WHEEL
       X=+0.07, Y=-0.085, Z=-0.04 -->
  <link name="front_right_wheel">
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0"
               iyy="0.0001" iyz="0.0"
               izz="0.0001"/>
    </inertial>
    <visual>
      <geometry>
        <cylinder radius="0.025" length="0.02"/>
      </geometry>
      <material name="red"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.025" length="0.02"/>
      </geometry>
    </collision>
  </link>

  <joint name="front_right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="front_right_wheel"/>
    <origin xyz="0.07 -0.085 -0.04" rpy="1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- REAR LEFT WHEEL
       X=-0.07, Y=+0.085, Z=-0.04 -->
  <link name="rear_left_wheel">
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0"
               iyy="0.0001" iyz="0.0"
               izz="0.0001"/>
    </inertial>
    <visual>
      <geometry>
        <cylinder radius="0.025" length="0.02"/>
      </geometry>
      <material name="red"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.025" length="0.02"/>
      </geometry>
    </collision>
  </link>

  <joint name="rear_left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="rear_left_wheel"/>
    <origin xyz="-0.07 0.085 -0.04" rpy="1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- REAR RIGHT WHEEL
       X=-0.07, Y=-0.085, Z=-0.04 -->
  <link name="rear_right_wheel">
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0"
               iyy="0.0001" iyz="0.0"
               izz="0.0001"/>
    </inertial>
    <visual>
      <geometry>
        <cylinder radius="0.025" length="0.02"/>
      </geometry>
      <material name="red"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.025" length="0.02"/>
      </geometry>
    </collision>
  </link>

  <joint name="rear_right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="rear_right_wheel"/>
    <origin xyz="-0.07 -0.085 -0.04" rpy="1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

</robot>